# GitHub personal access token used by local API routes in development.
# Scope recommendation: public_repo (or repo if you need private repositories).
GITHUB_TOKEN=ghp_your_token_here

# ===================================
# Translation System (MyMemory API)
# ===================================
# No API key required! MyMemory is 100% free.
# The translation script uses MyMemory's free API with a generous 10,000 words/day limit.
# No registration or setup needed - just run: npm run i18n:translate-missing

